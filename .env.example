# Database - Use these exact values for Docker setup
DATABASE_URL="postgresql://otis:ChangeMe123!@localhost:5432/duncan_finance"

# NextAuth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key-min-32-chars-long"
